# PickMe by Lensaparty production environment example

# Required
APP_SECRET=replace-with-a-long-random-secret
APP_URL=https://pickme.yourdomain.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
DATABASE_URL=postgres://user:password@host:5432/pickme

# Optional but recommended if you want live Google Drive ingestion
GOOGLE_DRIVE_APPS_SCRIPT_URL=
GOOGLE_DRIVE_API_KEY=

# Optional monitoring webhook for server-side error alerts
MONITORING_WEBHOOK_URL=

# Optional only for file-storage/self-hosted fallback mode
PICKME_DATA_DIR=

